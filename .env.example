WORDPRESS_API_BASE=https://nagotosha.com/wp-json/wp/v2
WORDPRESS_REVALIDATE_SECONDS=300

# Optional: Google Search Console HTML tag verification for the Next app.
# Use only the content value, not the full meta tag.
GOOGLE_SITE_VERIFICATION=BDpiHCojyBHSJEc3Rg0fGZMOr6oPqrqOl6-mNZ5xMHY

# Optional: not required for public REST reads or article rendering.
# These are only for controlled WordPress write scripts, such as draft creation
# or media uploads. Leave blank unless you are intentionally running those tools.
# Never commit real credentials.
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=
